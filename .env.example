# Copy to ".env" or ".env.local" (never commit those files).
# Vite only exposes variables prefixed with VITE_.

# Leave unset in dev to use the Vite proxy to http://localhost:8080 (see vite.config.ts).
# Set for production builds pointing at your API origin, e.g.:
# VITE_API_BASE_URL=https://api.example.com

# VITE_API_BASE_URL=
